#!/usr/bin/bash

ROM_ROOT="/mnt/xibalba/roms"
COLLECTION_DIR="$HOME/.emulationstation/collections"

mkdir -p "$COLLECTION_DIR"

# Temporary file to avoid duplicates
TMP_FILE=$(mktemp)

find "$ROM_ROOT" -type f -name "gamelist.xml" | while read -r gamelist; do
    SYSTEM_DIR=$(dirname "$gamelist")

    # Extract path + genre pairs
    xmlstarlet sel -t -m "//game[genre]" \
        -v "concat(path,'|',genre)" -n "$gamelist" | while IFS="|" read -r path genre; do

        # Clean path (remove ./ if present)
        CLEAN_PATH="${path#./}"
        FULL_PATH="$SYSTEM_DIR/$CLEAN_PATH"

        # Normalize genre string (remove spaces around commas)
        genre=$(echo "$genre" | sed 's/ *, */,/g')

        # Split genres
        IFS=',' read -ra GENRES <<< "$genre"

        for g in "${GENRES[@]}"; do
            # Trim whitespace
            g=$(echo "$g" | xargs)

            # Skip empty
            [ -z "$g" ] && continue

            COLLECTION_FILE="$COLLECTION_DIR/custom-$g"

            echo "$FULL_PATH" >> "$COLLECTION_FILE"
        done
    done
done

# Remove duplicates in all generated files
for file in "$COLLECTION_DIR"/custom-*; do
    [ -f "$file" ] && sort -u "$file" -o "$file"
done

echo "Done building custom collections."
